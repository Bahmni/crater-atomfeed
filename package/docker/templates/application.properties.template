spring.datasource.url=jdbc:mysql://${CRATER_DB_HOST}:${CRATER_DB_PORT}/${CRATER_DB_NAME}
spring.datasource.username=${CRATER_DB_USERNAME}
spring.datasource.password=${CRATER_DB_PASSWORD}
spring.jpa.generate-ddl=false
spring.jpa.database-platform=org.hibernate.dialect.MySQLDialect
spring.jpa.show-sql=false
spring.jpa.hibernate.ddl-auto=none
# server.port=9020
liquibase.change-log=classpath:db/changelog/liquibase.xml
enable.scheduling=true

